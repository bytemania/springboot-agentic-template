{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(find . *)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(grep *)",
      "Bash(docker compose *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(curl -s *)",
      "Bash(curl http://localhost*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard *)",
      "Bash(sudo *)",
      "Bash(docker rm -f *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] Session ended. Reminder: run ./gradlew test before committing.'"
          }
        ]
      }
    ]
  }
}
